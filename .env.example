# ============================================================
# AI Dev Team — Environment Configuration  (v3.0)
# ============================================================
# Copy this to .env and fill in real values

# ── Messaging ────────────────────────────────────────────────
# Choose: discord | whatsapp | both | zeroclaw
#   zeroclaw — ZeroClaw daemon manages ALL channels (Discord, WhatsApp, Telegram,
#              Slack, Signal, iMessage …). discord.py and Twilio are bypassed.
#              Install ZeroClaw: https://github.com/zeroclaw-labs/zeroclaw
MESSAGING_PROVIDER=discord

# ── Discord ──────────────────────────────────────────────────
# Bot Token (from Discord Developer Portal → Applications)
DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE

# Channel IDs (right-click channel → Copy ID in Discord)
DISCORD_CHANNEL_ORDERS=YOUR_ORDERS_CHANNEL_ID
DISCORD_CHANNEL_PLANS=YOUR_PLANS_CHANNEL_ID
DISCORD_CHANNEL_ACTIVITY=YOUR_ACTIVITY_CHANNEL_ID
DISCORD_CHANNEL_REPORTS=YOUR_REPORTS_CHANNEL_ID

# Architect Discord User ID — only this user can approve plans
MANAGER_DISCORD_ID=YOUR_DISCORD_USER_ID

# ── WhatsApp / Twilio ─────────────────────────────────────────
# Sign up at https://twilio.com, enable WhatsApp sandbox
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# Twilio sandbox number (or your approved WhatsApp number)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Your WhatsApp number to receive orders & notifications
MANAGER_WHATSAPP=whatsapp:+60123456789
# Webhook URL: set in Twilio console → WhatsApp Sandbox Settings
# → When a message comes in: HTTP POST https://<ngrok-url>/webhook/whatsapp

# ── LLM Brain ─────────────────────────────────────────────────────────────────
# LLM_MODEL is the single knob to switch your agents' brain.
# LiteLLM routes to the right provider automatically from the model prefix.
#
#  Provider        LLM_MODEL example(s)                        Key needed
#  ─────────────── ──────────────────────────────────────────── ───────────────
#  OpenAI          gpt-4o  gpt-4.1  o3-mini  gpt-4o-mini        OPENAI_API_KEY
#  Anthropic       claude-opus-4  claude-sonnet-4  claude-haiku   ANTHROPIC_API_KEY
#  Google Gemini   gemini/gemini-2.5-pro  gemini/gemini-3-flash  GOOGLE_API_KEY
#  Groq (fast)     groq/llama-3.3-70b  groq/mixtral-8x7b         GROQ_API_KEY
#  Mistral         mistral/mistral-large  mistral/codestral       MISTRAL_API_KEY
#  Together AI     together_ai/meta-llama/Llama-3-70b-Instruct    TOGETHERAI_API_KEY
#  Ollama (local)  ollama/llama3.3  ollama/qwen2.5-coder:32b      (no key, free)
#  AWS Bedrock     bedrock/anthropic.claude-3-5-sonnet-20241022   AWS_* vars below
#  LM Studio       openai/local-model  + OPENAI_BASE_URL=...      (no key)
#  Custom OpenAI   openai/<model>      + OPENAI_BASE_URL=...      OPENAI_API_KEY

LLM_MODEL=gpt-4o

# OpenAI (also used as fallback by Azure / LM Studio / any OpenAI-compatible)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=

# Anthropic Claude
ANTHROPIC_API_KEY=

# Google Gemini / Vertex AI
GOOGLE_API_KEY=
GOOGLE_PROJECT=

# Groq (fastest inference -- great for iteration)
GROQ_API_KEY=

# Mistral AI
MISTRAL_API_KEY=

# Together AI
TOGETHERAI_API_KEY=

# Ollama (local, no API key needed -- just run: ollama serve)
OLLAMA_HOST=http://localhost:11434

# AWS Bedrock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION_NAME=us-east-1

# Max tokens per agent LLM call
OPENAI_MAX_TOKENS=4000

# ── Git / GitHub ─────────────────────────────────────────────
# Local directory where generated files are committed
GIT_WORKSPACE=./workspace
# GitHub Personal Access Token (repo scope) for PR creation
GITHUB_TOKEN=ghp_...
# GitHub repo for PR creation: owner/repo
GITHUB_REPO=your-org/your-repo

# ── Persistence ──────────────────────────────────────────────
# SQLite database path (logs & history survive restarts)
DB_PATH=./agent_mesh.db

# ── React UI ─────────────────────────────────────────────────
# Backend URL for the React UI (used in Docker / LAN access)
VITE_BACKEND_URL=http://localhost:8000

# ── Security ─────────────────────────────────────────────────
# CORS origins allowed to access the API (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── ZeroClaw Gateway ─────────────────────────────────────────
# Only needed when MESSAGING_PROVIDER=zeroclaw (or to enable ZeroClaw SOP routing
# alongside Discord/WhatsApp by setting ZEROCLAW_WEBHOOK_SECRET).
#
# ZeroClaw is a Rust-native AI assistant daemon that handles all messaging channels.
# Install: https://github.com/zeroclaw-labs/zeroclaw → ./install.sh → zeroclaw daemon
# Config:  copy zeroclaw.config.toml.example → ~/.zeroclaw/config.toml
# SOP:     copy zeroclaw.sop.yaml.example  → ~/.zeroclaw/workspace/sops/ai-devteam.yaml

# URL of your running ZeroClaw gateway (default port 42617)
ZEROCLAW_GATEWAY_URL=http://localhost:42617

# HMAC-SHA256 secret for webhook signature verification.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# Set the same value in your zeroclaw SOP hmac_sha256() call.
ZEROCLAW_WEBHOOK_SECRET=

# ─── Advanced Pipeline (v4.0) ─────────────────────────────────────────────────
# Max output tokens per agent LLM call (GPT-4o supports 16k).
OPENAI_MAX_TOKENS=4000

# How many times QA / Security gates may retry before proceeding.
MAX_RETRIES=2

# Max number of implementation phases when decomposing complex tasks.
MAX_SUBTASKS=5

# Set to true to actually run pytest, bandit, and npm-audit during pipeline.
# Requires: pip install pytest pytest-cov bandit   npm install (in workspace)
ENABLE_REAL_TOOLS=true

# Set to true to `docker build` after DevOps generates a Dockerfile.
# Requires Docker Desktop / daemon running.
DOCKER_BUILD=false

# Number of past agent memories to inject as context into each Architect call.
MEMORY_CONTEXT_K=5

# ─── IDE Integration (MCP) ────────────────────────────────────────────────────
# Exposes an MCP (Model Context Protocol) server at /mcp so that VS Code Copilot,
# Cursor AI, and Google Antigravity can invoke CoDevx tools directly from their
# chat/agent panels. Set to false to disable the /mcp routes.
MCP_ENABLED=true

# ─── IDE Copilot Bridge ───────────────────────────────────────────────────────
# Route CoDevx agent LLM calls through GitHub Copilot (or Cursor AI) instead of
# — or alongside — OpenAI. This lets the 8 agents use Copilot's intelligence
# with your existing subscription (no extra API key needed).
#
# Providers:
#   openai   -- default: use OPENAI_API_KEY above
#   copilot  -- use GitHub Copilot via the codevx-vscode-bridge VS Code extension
#   cursor   -- alias for copilot (same bridge protocol, works with Cursor)
#   simulate -- always simulate (no LLM calls, for pipeline testing)
#
# Setup:
#   1. Open VS Code in this workspace
#   2. Install the codevx-vscode-bridge extension (see codevx-vscode-bridge/README.md)
#   3. The bridge auto-starts on port 8001 when VS Code opens
#   4. Set LLM_PROVIDER=copilot below
LLM_PROVIDER=openai

# URL of the running codevx-vscode-bridge extension HTTP server.
# Only needed when LLM_PROVIDER=copilot or LLM_PROVIDER=cursor.
COPILOT_BRIDGE_URL=http://localhost:8001

# ─── IDE Chatbot Tools (agents consult IDE chatbots DURING pipeline work) ────
# The agents' LLM brain (LLM_PROVIDER) is unchanged; these are additional
# specialist consultations — e.g. Copilot reviews backend code after it's
# generated, QA agent asks Copilot to suggest edge-case tests, Security agent
# asks Copilot to spot vulnerabilities before running bandit.
#
# IDE_TOOLS_ENABLED — set true to activate chatbot consultations
IDE_TOOLS_ENABLED=false

# IDE_CHATBOT — which IDE chatbot(s) to consult
#   copilot     — GitHub Copilot via the codevx-vscode-bridge extension (:8001)
#   cursor      — Cursor AI via the same bridge (Cursor is a VS Code fork)
#   antigravity — Google Antigravity IDE; uses Gemini via GOOGLE_API_KEY (see LLM Brain above)
#   all         — consult all three and combine their responses
IDE_CHATBOT=copilot

# Antigravity: uses GOOGLE_API_KEY (set above in LLM Brain section).
# Choose which Gemini model CoDevx consults when IDE_CHATBOT=antigravity:
#   gemini/gemini-2.5-pro  (same model Antigravity uses at "high" setting)
#   gemini/gemini-3-flash  (faster, lower cost)
ANTIGRAVITY_MODEL=gemini/gemini-2.5-pro
